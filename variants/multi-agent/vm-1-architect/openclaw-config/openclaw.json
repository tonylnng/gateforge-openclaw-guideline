// =============================================================================
// GateForge — VM-1: System Architect (Hub)
// =============================================================================
// Location: ~/.openclaw/openclaw.json
// This is the HUB — all spoke VMs communicate through this VM only.
//
// BEFORE EDITING: cp ~/.openclaw/openclaw.json ~/.openclaw/openclaw.json.bak
// AFTER EDITING:  openclaw doctor --fix && openclaw gateway restart
//
// Environment variables (${VAR}) are resolved from:
//   1. Shell environment
//   2. /opt/secrets/gateforge.env (sourced by the setup script)
// =============================================================================
{
  // -------------------------------------------------------------------------
  // Gateway — listens on Tailscale interface, token-protected
  // -------------------------------------------------------------------------
  gateway: {
    port: 18789,
    bind: "loopback",                     // Tailscale Serve handles external HTTPS access
    auth: {
      mode: "token",
      token: "${GATEWAY_AUTH_TOKEN}",    // From /opt/secrets/gateforge.env
      allowTailscale: false              // Require token even from Tailscale peers
    },
    reload: {
      mode: "hybrid",                   // Hot-reload safe changes, restart for critical
      debounceMs: 300
    }
  },

  // -------------------------------------------------------------------------
  // Webhooks — inbound hook endpoint for spoke notifications
  // -------------------------------------------------------------------------
  // Spokes POST to https://<VM1_TS_DOMAIN>:18789/hooks/agent with Bearer token.
  // The Architect also dispatches TO spokes via their /hooks/agent endpoints
  // using each spoke's Tailscale MagicDNS hostname (e.g.
  // https://tonic-designer.sailfish-bass.ts.net:18789/hooks/agent).
  hooks: {
    enabled: true,
    token: "${ARCHITECT_HOOK_TOKEN}",    // Dedicated hook token (NOT the gateway token)
    path: "/hooks",
    defaultSessionKey: "hook:gateforge",
    allowRequestSessionKey: true,
    allowedSessionKeyPrefixes: ["hook:", "gateforge:"],
    mappings: [
      // Map spoke notifications to the Architect agent
      {
        match: { path: "agent" },
        action: "agent",
        agentId: "architect",
        deliver: true
      }
    ]
  },

  // -------------------------------------------------------------------------
  // Agents — single Architect agent on this VM
  // -------------------------------------------------------------------------
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "anthropic/claude-opus-4-6",
        fallbacks: ["anthropic/claude-sonnet-4-6"]
      },
      sandbox: {
        mode: "non-main",               // Sandbox sub-agent code execution
        scope: "agent"
      },
      heartbeat: {
        every: "30m",
        mode: "next-heartbeat"
      }
    },
    list: [
      {
        id: "architect",
        default: true,
        name: "System Architect",
        workspace: "~/.openclaw/workspace",
        groupChat: {
          mentionPatterns: ["@architect", "architect"]
        }
      }
    ]
  },

  // -------------------------------------------------------------------------
  // Channels — Telegram for human operator interaction
  // -------------------------------------------------------------------------
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: ["${TELEGRAM_ALLOWED_USER_ID}"]
    }
  },

  // -------------------------------------------------------------------------
  // Bindings — route Telegram messages to the Architect agent
  // -------------------------------------------------------------------------
  bindings: [
    {
      agentId: "architect",
      match: { channel: "telegram" }
    }
  ],

  // -------------------------------------------------------------------------
  // Sessions
  // -------------------------------------------------------------------------
  session: {
    dmScope: "per-channel-peer",
    reset: {
      mode: "idle",
      idleMinutes: 240                  // Reset after 4 hours idle
    }
  },

  // -------------------------------------------------------------------------
  // Cron — enabled for scheduled tasks (Blueprint checks, health monitoring)
  // -------------------------------------------------------------------------
  cron: {
    enabled: true,
    maxConcurrentRuns: 2
  },

  // -------------------------------------------------------------------------
  // Tools
  // -------------------------------------------------------------------------
  tools: {
    web: {
      search: {
        provider: "brave",
        apiKey: "${BRAVE_SEARCH_API_KEY}"
      }
    }
  },

  // -------------------------------------------------------------------------
  // Environment variable references
  // -------------------------------------------------------------------------
  env: {
    ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}"
  },

  // -------------------------------------------------------------------------
  // Logging
  // -------------------------------------------------------------------------
  logging: {
    level: "info",
    consoleLevel: "warn"
  }
}
