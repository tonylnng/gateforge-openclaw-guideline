// =============================================================================
// GateForge — VM-5: Operator (Spoke)
// =============================================================================
// Location: ~/.openclaw/openclaw.json
// This is a SPOKE — communicates only with VM-1 Architect (Hub).
// The Operator handles CI/CD, deployment, and infrastructure monitoring.
//
// BEFORE EDITING: cp ~/.openclaw/openclaw.json ~/.openclaw/openclaw.json.bak
// AFTER EDITING:  openclaw doctor --fix && openclaw gateway restart
//
// Environment variables (${VAR}) are resolved from:
//   1. Shell environment
//   2. /opt/secrets/gateforge.env (sourced by the setup script)
// =============================================================================
{
  // -------------------------------------------------------------------------
  // Gateway — listens on Tailscale interface, token-protected
  // -------------------------------------------------------------------------
  gateway: {
    port: 18789,
    bind: "loopback",
    tailscale: {
      mode: "serve",
      resetOnExit: false
    },
    auth: {
      mode: "token",
      token: "${GATEWAY_AUTH_TOKEN}",
      allowTailscale: false
    },
    reload: {
      mode: "hybrid",
      debounceMs: 300
    }
  },

  // -------------------------------------------------------------------------
  // Webhooks — receives deployment/ops commands from the Architect
  // -------------------------------------------------------------------------
  hooks: {
    enabled: true,
    token: "${GATEWAY_AUTH_TOKEN}",
    path: "/hooks",
    defaultSessionKey: "hook:gateforge",
    allowRequestSessionKey: true,
    allowedSessionKeyPrefixes: ["hook:", "gateforge:", "ops:"],
    mappings: [
      {
        match: { path: "agent" },
        action: "agent",
        agentId: "operator",
        deliver: true
      }
    ]
  },

  // -------------------------------------------------------------------------
  // Agents — single Operator agent
  // -------------------------------------------------------------------------
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "minimax/MiniMax-M2.7",
        fallbacks: ["anthropic/claude-sonnet-4-6"]
      },
      sandbox: {
        mode: "non-main",
        scope: "agent"
      },
      heartbeat: {
        every: "30m",
        mode: "next-heartbeat"
      }
    },
    list: [
      {
        id: "operator",
        default: true,
        name: "Operator",
        workspace: "~/.openclaw/workspace",
        // Operator needs broader tool access for deployment tasks
        tools: {
          allow: ["exec", "read", "write", "edit", "apply_patch", "process", "browser", "cron", "web_fetch"]
        }
      }
    ]
  },

  // -------------------------------------------------------------------------
  // Sessions
  // -------------------------------------------------------------------------
  session: {
    dmScope: "per-channel-peer",
    reset: {
      mode: "idle",
      idleMinutes: 120
    }
  },

  // -------------------------------------------------------------------------
  // Cron — enabled for Operator (health checks, deployment monitoring)
  // -------------------------------------------------------------------------
  cron: {
    enabled: true,
    maxConcurrentRuns: 1
  },

  // -------------------------------------------------------------------------
  // Environment variable references
  // -------------------------------------------------------------------------
  env: {
    MINIMAX_API_KEY: "${MINIMAX_API_KEY}",
    ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}"
  },

  // -------------------------------------------------------------------------
  // Logging
  // -------------------------------------------------------------------------
  logging: {
    level: "info",
    consoleLevel: "warn"
  }
}
