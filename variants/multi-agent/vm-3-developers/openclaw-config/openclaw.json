// =============================================================================
// GateForge — VM-3: Developers (Spoke)
// =============================================================================
// Location: ~/.openclaw/openclaw.json
// This is a SPOKE — communicates only with VM-1 Architect (Hub).
// Supports multiple developer agents (dev-01, dev-02, ...) in one Gateway.
//
// BEFORE EDITING: cp ~/.openclaw/openclaw.json ~/.openclaw/openclaw.json.bak
// AFTER EDITING:  openclaw doctor --fix && openclaw gateway restart
//
// Environment variables (${VAR}) are resolved from:
//   1. Shell environment
//   2. /opt/secrets/gateforge.env (sourced by the setup script)
// =============================================================================
{
  // -------------------------------------------------------------------------
  // Gateway — listens on Tailscale interface, token-protected
  // -------------------------------------------------------------------------
  gateway: {
    port: 18789,
    bind: "loopback",
    tailscale: {
      mode: "serve",
      resetOnExit: false
    },
    auth: {
      mode: "token",
      token: "${GATEWAY_AUTH_TOKEN}",
      allowTailscale: false
    },
    reload: {
      mode: "hybrid",
      debounceMs: 300
    }
  },

  // -------------------------------------------------------------------------
  // Webhooks — receives task dispatches from the Architect
  // -------------------------------------------------------------------------
  hooks: {
    enabled: true,
    token: "${GATEWAY_AUTH_TOKEN}",
    path: "/hooks",
    defaultSessionKey: "hook:gateforge",
    allowRequestSessionKey: true,
    allowedSessionKeyPrefixes: ["hook:", "gateforge:", "dev:"],
    mappings: [
      // Default: route to dev-01 (Architect specifies agentId in payload)
      {
        match: { path: "agent" },
        action: "agent",
        agentId: "dev-01",
        deliver: true
      }
    ]
  },

  // -------------------------------------------------------------------------
  // Agents — multiple Developer agents sharing one Gateway
  // -------------------------------------------------------------------------
  // Each dev agent has its own workspace, memory, and session store.
  // The Architect dispatches tasks to specific agents via hook sessionKey.
  //
  // Adjust the list below to match your developer count (default: 3).
  // The setup script generates this section based on your choice.
  agents: {
    defaults: {
      model: {
        primary: "anthropic/claude-sonnet-4-6",
        fallbacks: ["anthropic/claude-sonnet-4-6"]
      },
      sandbox: {
        mode: "all",                     // Full Docker sandbox for code execution
        scope: "agent",
        docker: {
          image: "openclaw-sandbox:bookworm-slim",
          setupCommand: "apt-get update && apt-get install -y git curl nodejs npm",
          network: "none",               // No outbound network from sandbox
          readOnlyRoot: false,           // Developers need write access
          cpus: "1",
          memoryMb: 1024
        }
      },
      heartbeat: {
        every: "30m",
        mode: "next-heartbeat"
      },
      // Developer-specific tools
      tools: {
        allow: ["exec", "read", "write", "edit", "apply_patch", "process", "browser"]
      }
    },
    list: [
      {
        id: "dev-01",
        default: true,
        name: "Developer 01",
        workspace: "~/.openclaw/workspace-dev-01",
        agentDir: "~/.openclaw/agents/dev-01/agent"
      },
      {
        id: "dev-02",
        name: "Developer 02",
        workspace: "~/.openclaw/workspace-dev-02",
        agentDir: "~/.openclaw/agents/dev-02/agent"
      },
      {
        id: "dev-03",
        name: "Developer 03",
        workspace: "~/.openclaw/workspace-dev-03",
        agentDir: "~/.openclaw/agents/dev-03/agent"
      }
      // Add more agents as needed:
      // { id: "dev-04", name: "Developer 04", workspace: "~/.openclaw/workspace-dev-04", agentDir: "~/.openclaw/agents/dev-04/agent" },
      // { id: "dev-05", name: "Developer 05", workspace: "~/.openclaw/workspace-dev-05", agentDir: "~/.openclaw/agents/dev-05/agent" },
    ]
  },

  // -------------------------------------------------------------------------
  // Sessions
  // -------------------------------------------------------------------------
  session: {
    dmScope: "per-channel-peer",
    reset: {
      mode: "idle",
      idleMinutes: 120
    }
  },

  // -------------------------------------------------------------------------
  // Cron — disabled on spokes
  // -------------------------------------------------------------------------
  cron: {
    enabled: false
  },

  // -------------------------------------------------------------------------
  // Environment variable references
  // -------------------------------------------------------------------------
  env: {
    ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}"
  },

  // -------------------------------------------------------------------------
  // Logging
  // -------------------------------------------------------------------------
  logging: {
    level: "info",
    consoleLevel: "warn"
  }
}
