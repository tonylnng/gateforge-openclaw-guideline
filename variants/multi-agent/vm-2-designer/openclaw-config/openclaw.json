// =============================================================================
// GateForge — VM-2: System Designer (Spoke)
// =============================================================================
// Location: ~/.openclaw/openclaw.json
// This is a SPOKE — communicates only with VM-1 Architect (Hub).
//
// BEFORE EDITING: cp ~/.openclaw/openclaw.json ~/.openclaw/openclaw.json.bak
// AFTER EDITING:  openclaw doctor --fix && openclaw gateway restart
//
// Environment variables (${VAR}) are resolved from:
//   1. Shell environment
//   2. /opt/secrets/gateforge.env (sourced by the setup script)
// =============================================================================
{
  // -------------------------------------------------------------------------
  // Gateway — listens on Tailscale interface, token-protected
  // -------------------------------------------------------------------------
  gateway: {
    port: 18789,
    bind: "loopback",
    tailscale: {
      mode: "serve",
      resetOnExit: false
    },
    auth: {
      mode: "token",
      token: "${GATEWAY_AUTH_TOKEN}",    // Unique per-VM token (generated by VM-1 setup)
      allowTailscale: false
    },
    reload: {
      mode: "hybrid",
      debounceMs: 300
    }
  },

  // -------------------------------------------------------------------------
  // Webhooks — receives task dispatches from the Architect
  // -------------------------------------------------------------------------
  // Architect POSTs to https://<VM2_TS_DOMAIN>:18789/hooks/agent to dispatch tasks
  // (e.g. https://tonic-designer.sailfish-bass.ts.net:18789/hooks/agent).
  hooks: {
    enabled: true,
    token: "${GATEWAY_AUTH_TOKEN}",      // Spokes use their gateway token for hooks
    path: "/hooks",
    defaultSessionKey: "hook:gateforge",
    allowRequestSessionKey: true,
    allowedSessionKeyPrefixes: ["hook:", "gateforge:"],
    mappings: [
      {
        match: { path: "agent" },
        action: "agent",
        agentId: "designer",
        deliver: true
      }
    ]
  },

  // -------------------------------------------------------------------------
  // Agents — single Designer agent on this VM
  // -------------------------------------------------------------------------
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "anthropic/claude-sonnet-4-6",
        fallbacks: ["anthropic/claude-sonnet-4-6"]
      },
      sandbox: {
        mode: "non-main",
        scope: "agent"
      },
      heartbeat: {
        every: "30m",
        mode: "next-heartbeat"
      }
    },
    list: [
      {
        id: "designer",
        default: true,
        name: "System Designer",
        workspace: "~/.openclaw/workspace",
        groupChat: {
          mentionPatterns: ["@designer", "designer"]
        }
      }
    ]
  },

  // -------------------------------------------------------------------------
  // Sessions
  // -------------------------------------------------------------------------
  session: {
    dmScope: "per-channel-peer",
    reset: {
      mode: "idle",
      idleMinutes: 120
    }
  },

  // -------------------------------------------------------------------------
  // Cron — disabled on spokes (only the Architect schedules work)
  // -------------------------------------------------------------------------
  cron: {
    enabled: false
  },

  // -------------------------------------------------------------------------
  // Tools — Designer needs web search for research
  // -------------------------------------------------------------------------
  tools: {
    web: {
      search: {
        provider: "brave",
        apiKey: "${BRAVE_SEARCH_API_KEY}"
      }
    }
  },

  // -------------------------------------------------------------------------
  // Environment variable references
  // -------------------------------------------------------------------------
  env: {
    ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}"
  },

  // -------------------------------------------------------------------------
  // Logging
  // -------------------------------------------------------------------------
  logging: {
    level: "info",
    consoleLevel: "warn"
  }
}
